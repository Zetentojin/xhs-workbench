# Public-access Docker deployment defaults.
# This version is intentionally no-login and opens directly for use.
PUBLIC_ACCESS_ENABLED=1
NEXT_PUBLIC_PUBLIC_ACCESS=1

# Internal container networking for the frontend proxy.
BACKEND_URL=http://backend:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Bundled script and export directory mounts.
XHS_ENRICH_SCRIPT=/app/external/xhs_enrich.py
XHS_ENRICH_SCRIPT_HOST=./backend/external/xhs_enrich.py
XHS_ENRICH_OUTPUT_DIR=/app/exports
XHS_ENRICH_OUTPUT_DIR_HOST=./exports

# Optional binary overrides.
# XHS_BIN=/absolute/path/to/xhs
# OPENCLAW_BIN=/absolute/path/to/openclaw
